# Copy to .env (cp .env.sample .env) and fill in.
# Real environment variables override these values.

# Discord bot token (required)
BOT_TOKEN=your-bot-token-here

# Optional: guild (server) ID for instant command registration during development.
# Leave unset in production to register commands globally (propagation can take ~1h).
#DEV_GUILD_ID=123456789012345678
